      "resultContainer": {
        "type": "vertical",
        "gap": 4
      }
    },
    "layout_zones": [
      {
        "zone_id": "mainFormZone",
        "component": "formCard",
        "anchor": "center",
        "size_hint": "auto",
        "z_layer": "base",
        "notes": "Centered card containing the full GPA calculator form, inputs, button, feedback and result"
      },
      {
        "zone_id": "feedbackZone",
        "component": "feedbackContainer",
        "anchor": "center",
        "size_hint": "full-width",
        "z_layer": "base",
        "notes": "Alert messages shown conditionally based on messageType state; role=alert for screen readers"
      },
      {
        "zone_id": "resultZone",
        "component": "resultContainer",
        "anchor": "center",
        "size_hint": "full-width",
        "z_layer": "base",
        "notes": "GPA result display shown only when gpaResult is not null; animates in with opacity transition"
      }
    ]
  }
}
