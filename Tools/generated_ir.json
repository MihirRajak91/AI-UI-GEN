        "gap": 0
      },
      "gpaForm": {
        "type": "vertical",
        "gap": 0
      },
      "subject1FormItem": {
        "type": "vertical",
        "gap": 4
      },
      "subject2FormItem": {
        "type": "vertical",
        "gap": 4
      },
      "subject3FormItem": {
        "type": "vertical",
        "gap": 4
      },
