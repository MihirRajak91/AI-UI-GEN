{
  "page_ir": {
    "page_goal": "Personal details page with profile form fields, client-side validation, save draft and submit actions, responsive layout, and accessibility labels",
    "style": {
      "tone": "professional",
      "theme": "light",
      "density": "comfortable",
      "color_intent": "neutral"
    },
    "accessibility": {
      "required_labels": [
        "firstName",
        "lastName",
        "email",
        "phone",
        "dateOfBirth",
        "address",
        "city",
        "country",
        "postalCode",
        "saveDraftButton",
        "submitButton"
      ]
    },
    "responsive": {
      "breakpoints": {
        "mobile": 576,
        "tablet": 768,
        "desktop": 1024
      },
      "collapse_rules": [
        "Stack form fields vertically on mobile",
        "Two-column layout on tablet and above"
      ],
      "hidden_on_small": []
    },
    "constraints": [
      "Email must be valid format",
      "Phone must be valid format",
      "All required fields must be filled before submit"
    ]
  },
  "data_ir": {
    "state": {
      "firstName": {
        "type": "string",
        "initial": "",
        "required": true,
        "constraints": {
          "minLength": 1,
          "maxLength": 50
        }
      },
      "lastName": {
        "type": "string",
        "initial": "",
        "required": true,
        "constraints": {
          "minLength": 1,
          "maxLength": 50
        }
      },
      "email": {
        "type": "string",
        "initial": "",
        "required": true,
        "constraints": {
          "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
        }
      },
      "phone": {
        "type": "string",
        "initial": "",
        "required": false,
        "constraints": {
          "pattern": "^[+]?[(]?[0-9]{1,4}[)]?[-\\s\\.]?[(]?[0-9]{1,4}[)]?[-\\s\\.]?[0-9]{1,9}$"
        }
      },
      "dateOfBirth": {
        "type": "date",
        "initial": null,
        "required": false,
        "constraints": {}
      },
      "address": {
        "type": "string",
        "initial": "",
        "required": false,
        "constraints": {
          "maxLength": 200
        }
      },
      "city": {
        "type": "string",
        "initial": "",
        "required": false,
        "constraints": {
          "maxLength": 100
        }
      },
      "country": {
        "type": "string",
        "initial": "",
        "required": false,
        "constraints": {
          "maxLength": 100
        }
      },
      "postalCode": {
        "type": "string",
        "initial": "",
        "required": false,
        "constraints": {
          "maxLength": 20
        }
      },
      "isDraft": {
        "type": "boolean",
        "initial": true,
        "required": false,
        "constraints": {}
      },
      "isSubmitting": {
        "type": "boolean",
        "initial": false,
        "required": false,
        "constraints": {}
      }
    },
    "derived": {
      "isFormValid": {
        "type": "boolean",
        "expr": "state.firstName.length > 0 && state.lastName.length > 0 && /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(state.email)"
      },
      "formCompleteness": {
        "type": "number",
        "expr": "((state.firstName ? 1 : 0) + (state.lastName ? 1 : 0) + (state.email ? 1 : 0) + (state.phone ? 1 : 0) + (state.dateOfBirth ? 1 : 0) + (state.address ? 1 : 0) + (state.city ? 1 : 0) + (state.country ? 1 : 0) + (state.postalCode ? 1 : 0)) / 9 * 100"
      }
    }
  },
  "data_model_ir": {
    "entities": {
      "personalDetails": {
        "name": "PersonalDetails",
        "fields": [
          "firstName",
          "lastName",
          "email",
          "phone",
          "dateOfBirth",
          "address",
          "city",
          "country",
          "postalCode"
        ],
        "computed": [
          "isFormValid",
          "formCompleteness"
        ],
        "display_fields": [
          "firstName",
          "lastName",
          "email"
        ],
        "filters": []
      }
    }
  },
  "behaviour_ir": {
    "events": {
      "updateFirstName": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.firstName",
            "expr": "event.target.value"
          }
        ]
      },
      "updateLastName": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.lastName",
            "expr": "event.target.value"
          }
        ]
      },
      "updateEmail": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.email",
            "expr": "event.target.value"
          }
        ]
      },
      "updatePhone": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.phone",
            "expr": "event.target.value"
          }
        ]
      },
      "updateDateOfBirth": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.dateOfBirth",
            "expr": "event"
          }
        ]
      },
      "updateAddress": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.address",
            "expr": "event.target.value"
          }
        ]
      },
      "updateCity": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.city",
            "expr": "event.target.value"
          }
        ]
      },
      "updateCountry": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.country",
            "expr": "event.target.value"
          }
        ]
      },
      "updatePostalCode": {
        "type": "mutation",
        "updates": [
          {
            "target": "state.postalCode",
            "expr": "event.target.value"
          }
        ]
      }
    },
    "actions": {
      "saveDraft": {
        "action_id": "saveDraft",
        "trigger": "button_click",
        "target_component_id": "saveDraftButton",
        "operation": "save_draft",
        "payload": {
          "firstName": "state.firstName",
          "lastName": "state.lastName",
          "email": "state.email",
          "phone": "state.phone",
          "dateOfBirth": "state.dateOfBirth",
          "address": "state.address",
          "city": "state.city",
          "country": "state.country",
          "postalCode": "state.postalCode",
          "isDraft": true
        },
        "validation_rules": [],
        "requires_confirmation": false,
        "updates": [
          {
            "target": "state.isDraft",
            "expr": "true"
          }
        ]
      },
      "submitForm": {
        "action_id": "submitForm",
        "trigger": "button_click",
        "target_component_id": "submitButton",
        "operation": "submit_form",
        "payload": {
          "firstName": "state.firstName",
          "lastName": "state.lastName",
          "email": "state.email",
          "phone": "state.phone",
          "dateOfBirth": "state.dateOfBirth",
          "address": "state.address",
          "city": "state.city",
          "country": "state.country",
          "postalCode": "state.postalCode",
          "isDraft": false
        },
        "validation_rules": [
          "state.firstName.length > 0",
          "state.lastName.length > 0",
          "/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(state.email)"
        ],
        "requires_confirmation": true,
        "updates": [
          {
            "target": "state.isSubmitting",
            "expr": "true"
          },
          {
            "target": "state.isDraft",
            "expr": "false"
          }
        ]
      }
    },
    "feedback": {
      "saveDraft": {
        "action_id": "saveDraft",
        "loading_indicator": "spinner",
        "success_message": "Draft saved successfully",
        "error_message": "Failed to save draft. Please try again.",
        "ui_updates": []
      },
      "submitForm": {
        "action_id": "submitForm",
        "loading_indicator": "spinner",
        "success_message": "Personal details submitted successfully",
        "error_message": "Failed to submit form. Please check all required fields and try again.",
        "ui_updates": [
          {
            "target": "state.isSubmitting",
            "expr": "false"
          }
        ]
      }
    }
  },
  "component_ir": {
    "library": "antd",
    "theme": {
      "primaryColor": "#1677ff",
      "secondaryColor": "#52c41a",
      "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "borderRadius": 8
    },
    "components": {
