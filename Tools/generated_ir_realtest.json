      "formContainer": {
        "type": "vertical",
        "gap": 0
      },
      "basicInfoSection": {
        "type": "vertical",
        "gap": 16
      },
      "nameRow": {
        "type": "horizontal",
        "gap": 16
      },
      "contactRow": {
