        "zone_id": "main_form_zone",
        "component": "formContainer",
        "anchor": "center",
        "size_hint": "full-width",
        "z_layer": "base",
        "notes": "Main form container with all personal details fields"
      },
      {
        "zone_id": "action_buttons_zone",
        "component": "buttonRow",
        "anchor": "bottom-right",
        "size_hint": "auto",
        "z_layer": "base",
        "notes": "Action buttons for save draft and submit"
      }
    ]
  }
}
