              "required": true,
              "message": "Please enter your email"
            },
            {
              "type": "email",
              "message": "Please enter a valid email"
            }
          ]
        },
        "styles": {}
      },
      "emailInput": {
        "type": "Input",
        "label": null,
        "bind": "state.email",
        "onClick": null,
        "props": {
          "placeholder": "Enter email address",
          "type": "email",
          "aria-label": "Email",
          "onChange": "updateEmail"
        },
