          "className": "form-section"
        },
        "styles": {
          "marginBottom": "32px"
        }
      },
      "sectionTitle": {
        "type": "Typography.Title",
        "label": "Basic Information",
        "bind": null,
        "onClick": null,
        "props": {
          "level": 3
        },
        "styles": {
          "marginBottom": "16px"
        }
      },
      "nameRow": {
        "type": "Row",
        "label": null,
        "bind": null,
        "onClick": null,
